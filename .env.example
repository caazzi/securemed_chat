# This direnv command activates your Python virtual environment (if using direnv)
layout pyenv smc-env

# Frontend API connectivity
export API_BASE_URL="http://localhost:8080/api"

# Shared local API key (Used by frontend to auth against backend)
export SECUREMED_API_KEY="development_key_123"

# Google Cloud Vertex AI (LLM) Configuration
# Replace these with your actual GCP Project ID and path to the JSON key file.
# export GOOGLE_CLOUD_PROJECT="your_project_id_here"
# export GOOGLE_APPLICATION_CREDENTIALS="/absolute/path/to/credentials.json"
