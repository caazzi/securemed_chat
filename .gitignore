# --- Python Virtual Environment ---
# Ignore the virtual environment folder created by tools like venv, virtualenv
# In your case, it looks like the environment is in the ".direnv" or "python-3.10.6" directory
.direnv/
python-3.10.6/

# --- Environment Variables ---
# Ignore environment variable files. These are sensitive and machine-specific.
.env
.envrc

# --- Python Cache and Compiled Files ---
# Ignore Python bytecode and cache folders
__pycache__/
*.pyc
*.pyo
*.pyd

# --- Jupyter Notebook ---
# Ignore the checkpoints directory created by Jupyter
.ipynb_checkpoints/

# --- Data & Model Files ---
# It's often a good practice to ignore large data files, datasets, or trained models.
# If your .pkl files are large, you should ignore them.
*.pkl

# If the PDFs in your knowledge_base are just for reference and not a core,
# versioned part of the project, you might want to ignore them too.
knowledge_base/*.pdf

# --- OS-specific files ---
# Ignore files generated by macOS, Windows, and Linux editors
.DS_Store
Thumbs.db
*~
